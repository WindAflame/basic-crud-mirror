##########################################################################
### Dependancies
##########################################################################

install-apt:
	xargs apt-get -y install < apt-requirements.txt

install: 
	uv sync

##########################################################################
### Building
##########################################################################

build:
	pass

freeze:
	uv lock

##########################################################################
### Runtime
##########################################################################

dev: 
	uv run fastapi dev

start:
	uv run fastapi run